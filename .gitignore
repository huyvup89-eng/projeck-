print("\n" + "="*70)
print("✅ HOÀN THÀNH PHÂN TÍCH!")
print("="*70)
print(f"\n THỐNG KÊ CUỐI CÙNG:")
print(f"   • Tổng mẫu dữ liệu: {len(data)}")
print(f"   • Tập huấn luyện: {len(X_train)} mẫu")
print(f"   • Tập kiểm tra: {len(X_test)} mẫu")
print(f"   • Mô hình tốt nhất: {best_method}")
print(f"   • Độ chính xác: {accuracy * 100:.2f}%")
print(f"   • Chênh lệch Train-Test: {(acc_dt_train - acc_dt_test) * 100 if best_method == 'Decision Tree' else (acc_rf_train - acc_rf_test) * 100:.2f}%")

